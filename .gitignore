# ---- Xcode / Swift ----
# Generated by XcodeGen — never commit; run `xcodegen generate` after pulling.
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
build/
*.xcuserstate
*.moved-aside
.swiftpm/
.build/
Package.resolved

# ---- macOS ----
.DS_Store

# ---- Python (analysis/) ----
__pycache__/
*.py[cod]
.venv/
venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Recorded sensor data (large / binary, not for git) ----
analysis/data/*
!analysis/data/.gitkeep

# ---- dataset/ : SQLite is a rebuilt artifact; raw time-series are local ----
dataset/dataset.sqlite
dataset/raw/*
!dataset/raw/.gitkeep
