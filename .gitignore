# ---- Xcode / Swift ----
# Generated by XcodeGen — never commit; run `xcodegen generate` after pulling.
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
build/
*.xcuserstate
*.moved-aside
.swiftpm/
.build/
Package.resolved

# ---- macOS ----
.DS_Store

# ---- Python (analysis/) ----
__pycache__/
*.py[cod]
.venv/
venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Recorded sensor data (large / binary, not for git) ----
analysis/data/*
!analysis/data/.gitkeep

# ---- dataset/ ----
# SQLite is a rebuilt artifact (comments must be on their own line in .gitignore).
dataset/dataset.sqlite
# Raw data: COMMIT small text exports (WL .txt) so derived rows stay reproducible;
# keep large binary/IMU streams (watch/AirPods .csv, video) OUT of git.
dataset/raw/*
!dataset/raw/.gitkeep
!dataset/raw/*.txt
!dataset/raw/*.mp4
!dataset/raw/*.mov
!dataset/raw/manifest.csv
# HD masters live in R2 (docs/video-storage.md); resolve_clip() caches downloads
# here (gitignored) — only the manifest pointer is committed.
dataset/.clipcache/

# Generated plate-detector dataset + training runs (regenerate via build_plate_dataset.py;
# data.yaml carries a machine-specific absolute path, frames/weights are derived artifacts).
dataset/cv_plate/
