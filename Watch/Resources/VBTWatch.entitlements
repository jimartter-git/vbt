<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- HealthKit is the ONE capability the watch app genuinely can't function
     without: HKWorkoutSession is what keeps the motion sensors alive and blocks
     sleep mid-set. You must enable the HealthKit capability on this target in
     Xcode (Signing & Capabilities) for provisioning to match this entitlement. -->
<dict>
	<key>com.apple.developer.healthkit</key>
	<true/>
	<key>com.apple.developer.healthkit.access</key>
	<array/>
</dict>
</plist>
